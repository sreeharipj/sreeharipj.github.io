---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import {
  IDENTITY,
  TECH_STACK,
  FOCUS_AREAS,
  FEATURED_POSTS,
  SOCIAL_LINKS,
} from "@/config";
---

<Layout title={`Hi, I'm ${IDENTITY.firstName} | ${IDENTITY.alias}`} description={`Quick introduction to ${IDENTITY.fullName} (${IDENTITY.alias}) — ${IDENTITY.role}.`}>
  <Header />
  <main id="main-content" class="app-layout">
    <div class="relative max-w-3xl mx-auto px-0 pt-32 pb-24">

      <!-- Dot grid background -->
      <div class="fixed inset-0 pointer-events-none bg-[radial-gradient(circle,_rgba(255,255,255,0.03)_1px,_transparent_1px)] bg-[length:24px_24px] -z-10"></div>

      <!-- Profile Card -->
      <section class="metal-card rounded-3xl overflow-hidden mb-5 hi-card">
        <!-- Banner -->
        <div class="h-28 sm:h-36 bg-gradient-to-br from-[#001a1a] via-[#00121e] to-[#0a0a0a] relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_rgba(0,210,255,0.15),_transparent_60%)]"></div>
          <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
          <div class="absolute inset-0 bg-[linear-gradient(rgba(0,210,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,210,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
        </div>

        <div class="px-6 sm:px-8 pb-6 sm:pb-8 pt-0 relative">
          <!-- Avatar -->
          <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-2xl ring-4 ring-background bg-[#111] -mt-10 mb-4 flex items-center justify-center">
            <span class="text-4xl font-serif italic font-bold text-accent">{IDENTITY.firstName.charAt(0)}</span>
          </div>

          <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
            <div>
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <h1 class="text-xl sm:text-2xl font-semibold text-foreground">{IDENTITY.fullName}</h1>
                <span class="text-sm text-foreground/40 font-mono">{IDENTITY.handle}</span>
              </div>
              <p class="text-foreground/60 text-sm">{IDENTITY.role}</p>
            </div>
            <a href="/resume" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-white/5 hover:bg-white/10 text-foreground/70 hover:text-foreground transition-all border border-white/5 hover:border-white/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Resume
            </a>
          </div>

          <p class="text-sm sm:text-base text-foreground/70 leading-relaxed mb-6">{IDENTITY.bio}</p>

          <!-- Action Buttons -->
          <div class="flex flex-wrap gap-2 sm:gap-3 mb-6">
            <a href="/projects" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium bg-accent text-[#0a0a0a] hover:scale-105 hover:shadow-[0_0_20px_#00d2ff30] transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              View Projects
            </a>
            <a href={SOCIAL_LINKS.email} class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium border border-white/10 bg-white/5 text-foreground hover:bg-white/10 hover:border-white/20 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Drop a mail
            </a>
          </div>

          <!-- Social Links -->
          <div class="mb-6">
            <p class="text-xs text-foreground/40 mb-3 font-mono tracking-wide uppercase">Find me on the internet</p>
            <div class="flex flex-wrap gap-2">
              <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs bg-white/5 hover:bg-white/10 text-foreground/70 hover:text-foreground transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                GitHub
              </a>
              <a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs bg-white/5 hover:bg-white/10 text-foreground/70 hover:text-foreground transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
                Twitter / X
              </a>
              <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs bg-white/5 hover:bg-white/10 text-foreground/70 hover:text-foreground transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <!-- Tech Stack -->
          <div>
            <p class="text-xs text-foreground/40 mb-3 font-mono tracking-wide uppercase">My everyday toolkit</p>
            <div class="flex flex-wrap gap-2">
              {TECH_STACK.map(tech => (
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-white/5 bg-white/5 text-foreground/70 text-xs font-mono">
                  <span class="w-2 h-2 rounded-full" style={`background-color: ${tech.dotColor}`}></span>
                  {tech.label}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- What I Focus On -->
      <section class="metal-card rounded-3xl p-6 sm:p-8 mb-5 hi-card">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-5 w-1 rounded-full bg-accent/70"></div>
          <h2 class="text-base sm:text-lg font-semibold text-foreground">What I focus on</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {FOCUS_AREAS.map(area => (
            <div class="p-4 rounded-2xl bg-white/2 border border-white/5 hover:border-accent/20 transition-colors">
              <div class="text-2xl mb-3">{area.emoji}</div>
              <h3 class="text-sm font-semibold text-foreground mb-2">{area.title}</h3>
              <p class="text-xs text-foreground/50 leading-relaxed">{area.long}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Featured Research -->
      <section class="metal-card rounded-3xl p-6 sm:p-8 mb-5 hi-card">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-5 w-1 rounded-full bg-accent/70"></div>
          <h2 class="text-base sm:text-lg font-semibold text-foreground">Things I've written</h2>
        </div>
        <div class="space-y-3">
          {FEATURED_POSTS.map(post => (
            <a href={post.href} class="flex items-start gap-4 p-3 rounded-xl bg-white/2 border border-white/5 hover:border-accent/20 hover:bg-white/[0.04] transition-all group">
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-medium text-foreground group-hover:text-accent transition-colors line-clamp-1">{post.title}</h3>
                <div class="flex gap-2 mt-2">
                  {post.tags.slice(0, 2).map(tag => (
                    <span class={`text-[10px] px-2 py-0.5 rounded-md font-mono ${tag === post.tags[0] ? "bg-accent/10 text-accent" : "bg-white/10 text-foreground/60"}`}>{tag}</span>
                  ))}
                </div>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 text-foreground/20 group-hover:text-accent/60 transition-colors mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 5H19V11"/><path d="M19 5L5 19"/></svg>
            </a>
          ))}
        </div>
        <div class="flex justify-center mt-5">
          <a href="/posts" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-xs font-medium border border-white/10 bg-white/5 text-foreground/70 hover:bg-white/10 hover:text-foreground transition-all">
            Read all posts
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 5H19V11"/><path d="M19 5L5 19"/></svg>
          </a>
        </div>
      </section>

      <!-- Footer CTA -->
      <section class="text-center py-8">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="h-px w-16 bg-gradient-to-r from-transparent to-border/50"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-accent/40"></div>
          <div class="h-px w-16 bg-gradient-to-l from-transparent to-border/50"></div>
        </div>
        <p class="text-foreground/40 text-sm italic font-serif mb-6">"The best way to secure a system is to understand how to break it."</p>
        <a href="/" class="group inline-flex flex-col items-center gap-2">
          <span class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full text-sm font-medium border border-white/10 bg-white/5 text-accent hover:bg-white/10 hover:border-accent/20 transition-all duration-300 hover:shadow-[0_0_20px_#00d2ff15]">
            Explore Full Portfolio
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 5H19V11"/><path d="M19 5L5 19"/></svg>
          </span>
        </a>
        <p class="mt-6 text-xs text-foreground/25 font-mono">crafted from kernel space — <span class="text-accent/50">{IDENTITY.handle}</span></p>
      </section>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  .hi-card {
    animation: slideUp 0.5s ease forwards;
    opacity: 0;
  }
  .hi-card:nth-child(1) { animation-delay: 0.1s; }
  .hi-card:nth-child(2) { animation-delay: 0.2s; }
  .hi-card:nth-child(3) { animation-delay: 0.3s; }
  .hi-card:nth-child(4) { animation-delay: 0.4s; }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
