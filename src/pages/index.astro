---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import {
  IDENTITY,
  TECH_STACK,
  FOCUS_AREAS,
  INTERESTS,
  FEATURED_POSTS,
} from "@/config";
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-32 pb-16 sm:pt-40 sm:pb-24 flex flex-col items-center justify-center text-center gap-8 relative z-10">
      <div class="space-y-6 max-w-4xl">
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-serif italic font-bold leading-tight tracking-tight">
          Hey, I am {IDENTITY.firstName} <span class="text-foreground/30 font-sans font-light px-2">—</span><span class="font-sans not-italic font-bold bg-clip-text text-transparent bg-gradient-to-r from-accent to-[#bffff]">aka {IDENTITY.alias}</span>
        </h1>
        <h2 class="text-xl sm:text-2xl text-foreground/80 font-sans leading-relaxed tracking-wide">
          {IDENTITY.heroTagline.split("kernel-level tools").map((part, i) =>
            i === 0
              ? <>{part}<span class="text-accent font-semibold px-1 inline-block border-b-2 border-accent/30 pb-1">kernel-level tools</span></>
              : part
          )}
        </h2>
        <p class="text-base sm:text-lg text-foreground/50 font-sans max-w-2xl mx-auto">
          {IDENTITY.heroSubtext}
        </p>

        <!-- Tech Stack Pills -->
        <div class="flex flex-wrap items-center justify-center gap-3 pt-4">
          {TECH_STACK.map(tech => (
            <span class="font-mono text-sm px-4 py-1.5 rounded-full border border-white/5 bg-white/5 text-foreground/80 shadow-sm flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" style={`background-color: ${tech.dotColor}`}></span>
              {tech.label}
            </span>
          ))}
        </div>

        <!-- Centered Action Buttons -->
        <div class="flex flex-wrap items-center justify-center gap-4 pt-8">
          <a href="/projects" class="px-8 py-3.5 rounded-full bg-accent text-[#0a0a0a] font-semibold hover:scale-105 hover:shadow-[0_0_20px_#00d2ff40] transition-all duration-300">
            View Projects
          </a>
          <a href="/resume" class="px-8 py-3.5 rounded-full border border-white/10 bg-white/5 text-foreground hover:bg-white/10 hover:border-white/20 transition-all duration-300">
            View Resume
          </a>
        </div>

        <!-- Short on time CTA -->
        <div class="pt-6">
          <a href="/hi" class="group inline-flex items-center gap-2 text-sm text-foreground/50 hover:text-foreground/90 transition-colors duration-300">
            <span class="font-mono text-accent/70 group-hover:text-accent transition-colors">⚡</span>
            <span class="border-b border-dashed border-foreground/20 group-hover:border-foreground/60 transition-colors pb-px">Short on time? Here's the runthrough</span>
            <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- About Me Bento Card -->
    <section id="about-bento" class="pb-16 relative z-10">
      <div class="metal-card rounded-3xl overflow-hidden bg-[#0c0c0c]/80 shadow-2xl ring-1 ring-white/5">
        <div class="flex flex-col md:flex-row">
          <!-- Left: Identity Block -->
          <div class="md:w-2/5 p-8 sm:p-10 border-b md:border-b-0 md:border-r border-white/5 flex flex-col justify-between gap-8">
            <div>
              <div class="w-16 h-16 rounded-2xl bg-accent/10 ring-1 ring-accent/20 flex items-center justify-center mb-6">
                <span class="text-3xl font-serif italic font-bold text-accent">{IDENTITY.firstName.charAt(0)}</span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-serif italic font-bold text-foreground mb-2">{IDENTITY.fullName}</h2>
              <p class="text-accent font-mono text-sm tracking-wider mb-4">{IDENTITY.handle} · Systems & Security</p>
              <p class="text-foreground/60 text-sm sm:text-base leading-relaxed">
                {IDENTITY.bio}
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              {TECH_STACK.map(tech => (
                <span class="font-mono text-xs px-3 py-1 rounded-full border border-white/5 bg-white/5 text-foreground/70 flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${tech.dotColor}`}></span>
                  {tech.label}
                </span>
              ))}
            </div>
          </div>

          <!-- Right: Focus Areas Grid -->
          <div class="md:w-3/5 p-8 sm:p-10 grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <div class="text-accent font-mono text-xs tracking-widest uppercase mb-3 opacity-60">What I do</div>
              <div class="space-y-3">
                {FOCUS_AREAS.map(area => (
                  <div class="flex items-start gap-3">
                    <span class="text-accent mt-1 text-xs">▸</span>
                    <div>
                      <p class="text-foreground/90 text-sm font-medium">{area.title}</p>
                      <p class="text-foreground/50 text-xs leading-relaxed mt-0.5">{area.short}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="space-y-2">
              <div class="text-accent font-mono text-xs tracking-widest uppercase mb-3 opacity-60">Current Interests</div>
              <div class="space-y-3">
                {INTERESTS.map(interest => (
                  <div class="flex items-start gap-3">
                    <span class="text-foreground/20 mt-1 text-xs">▸</span>
                    <p class="text-foreground/60 text-xs leading-relaxed">{interest}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class="sm:col-span-2 pt-4 border-t border-white/5">
              <a href="/about" class="group inline-flex items-center gap-2 text-xs text-foreground/40 hover:text-accent transition-colors duration-300 font-mono tracking-wide">
                Full bio →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Research -->
    <section id="featured" class="pt-12 pb-6 border-b border-border">
      <h2 class="text-2xl font-serif font-bold tracking-wide mb-6 text-foreground">Featured Research</h2>
      <ul class="space-y-6">
        {FEATURED_POSTS.map(post => (
          <li>
            <a href={post.href} class="group block metal-card metal-card-hover p-6 bg-noise">
              <h3 class="text-xl font-medium text-foreground group-hover:text-accent transition-colors">
                {post.title}
              </h3>
              <div class="flex flex-wrap gap-2 mt-4">
                {post.tags.map(tag => (
                  <span class="font-mono text-xs bg-accent/10 px-2.5 py-1 rounded-md text-accent ring-1 ring-inset ring-accent/20">{tag}</span>
                ))}
              </div>
              <p class="mt-4 text-foreground/70 text-sm leading-relaxed">{post.excerpt}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
