import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import SystemNotice from "@/components/SystemNotice.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getCollection } from "astro:content";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import {
  IDENTITY,
  TECH_STACK,
  CURRENT_STATUS,
  PROJECTS,
  SOCIAL_LINKS,
  SITE,
} from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, SITE.postPerIndex).map(post => ({
  year: new Date(post.data.pubDatetime).getFullYear(),
  href: getPath(post.id, post.filePath),
  title: post.data.title,
  excerpt: post.data.description,
}));
---

<Layout>
  <SystemNotice />
  <Header />
  <main id="main-content" data-layout="index" class="app-layout pt-20 pb-24">
    <div class="fixed inset-0 z-[-1] pointer-events-none bg-[radial-gradient(circle,var(--dot-color)_1px,transparent_1px)] bg-[length:24px_24px]"></div>

    <!-- ─── HERO ─────────────────────────────────────────── -->
    <section class="py-12 sm:py-16">
      <div class="flex flex-col sm:flex-row gap-10 sm:gap-16">
        <!-- Left: Identity -->
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-serif italic font-normal mb-1" style="color: var(--foreground)">
            {IDENTITY.fullName}
          </h1>
          <p class="text-sm mb-5" style="color: var(--text-muted)">{IDENTITY.role}</p>
          <p class="text-sm leading-relaxed mb-6" style="color: var(--text-muted); max-width: 38ch">
            {IDENTITY.heroSubtext}
          </p>
          <!-- Links -->
          <div class="flex flex-wrap gap-x-2 gap-y-2 text-sm" style="color: var(--text-faint)">
            <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="prose-link px-2 py-1 hover:opacity-100 transition-opacity">github</a>
            <a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener noreferrer" class="prose-link px-2 py-1 hover:opacity-100 transition-opacity">twitter</a>
            <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="prose-link px-2 py-1 hover:opacity-100 transition-opacity">linkedin</a>
            <a href={SOCIAL_LINKS.email} class="prose-link px-2 py-1 hover:opacity-100 transition-opacity">email</a>
            <a href="/hi" class="prose-link px-2 py-1 hover:opacity-100 transition-opacity">short intro →</a>
          </div>
        </div>

        <!-- Right: Current Status -->
        <div class="sm:w-56 shrink-0">
          <p class="text-xs font-mono uppercase tracking-widest mb-4" style="color: var(--text-faint)">Currently</p>
          <div class="space-y-3">
            {CURRENT_STATUS.map(item => (
              <div>
                <span class="text-xs font-mono block mb-0.5" style="color: var(--text-faint)">{item.label}</span>
                <span class="text-sm" style="color: var(--text-muted)">{item.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <hr style="border-color: var(--hr-color)" />

    <!-- ─── PROJECTS TABLE ────────────────── -->
    <section class="py-10">
      <h2 class="text-xs font-mono uppercase tracking-widest mb-6" style="color: var(--text-faint)">Selected Projects</h2>

      <!-- Mobile: stacked cards -->
      <div class="sm:hidden space-y-6">
        {PROJECTS.map(project => (
          <div style="border-bottom: 1px solid var(--subtle-border); padding-bottom: 1.25rem">
            <div class="flex items-baseline gap-3 mb-1">
              <span class="text-xs font-mono" style="color: var(--text-faint)">{project.year}</span>
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-sm font-medium prose-link">{project.title}</a>
            </div>
            <p class="text-xs mb-1.5" style="color: var(--text-faint); font-family: var(--font-mono)">{project.stack}</p>
            <p class="text-xs leading-relaxed" style="color: var(--text-muted)">{project.description}</p>
          </div>
        ))}
      </div>

      <!-- Desktop: table -->
      <table class="research-table hidden sm:table">
        <thead>
          <tr>
            <th class="col-year">Year</th>
            <th class="col-title">Project</th>
            <th class="col-stack">Stack</th>
            <th class="col-desc">Description</th>
          </tr>
        </thead>
        <tbody>
          {PROJECTS.map(project => (
            <tr>
              <td class="col-year">{project.year}</td>
              <td class="col-title"><a href={project.link} target="_blank" rel="noopener noreferrer">{project.title}</a></td>
              <td class="col-stack">{project.stack}</td>
              <td class="col-desc">{project.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <hr style="border-color: var(--hr-color)" />

    <!-- ─── WRITING / BLOG POSTS ────────────────── -->
    <section class="py-10">
      <h2 class="text-xs font-mono uppercase tracking-widest mb-6" style="color: var(--text-faint)">Writing</h2>

      <div class="space-y-8">
        {recentPosts.map(post => (
          <div class="group flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-6">
            <span class="text-xs font-mono tabular-nums shrink-0" style="color: var(--text-faint)">{post.year}</span>
            <div class="flex-1 min-w-0">
              <a href={post.href} class="text-sm font-medium prose-link block mb-1">
                {post.title}
              </a>
              <p class="text-xs leading-relaxed" style="color: var(--text-muted); max-width: 65ch">
                {post.excerpt}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <LinkButton href="/posts/">
          All technical writing
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    <hr style="border-color: var(--hr-color)" />

    <!-- ─── TECH ──────────────────────────────────────────── -->
    <section class="py-10">
      <h2 class="text-xs font-mono uppercase tracking-widest mb-4" style="color: var(--text-faint)">Tools</h2>
      <div class="flex flex-wrap gap-3">
        {TECH_STACK.map(tech => (
          <span class="text-xs font-mono px-2 py-1" style="color: var(--text-muted); border: 1px solid var(--subtle-border)">
            {tech.label}
          </span>
        ))}
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
