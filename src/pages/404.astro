---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="relative h-screen flex flex-col items-center justify-center overflow-hidden"
  >
    <!-- Removed object-cover, we will rely on precise JS canvas sizing now -->
    <canvas id="c" class="absolute inset-0 z-0 opacity-40"></canvas>
    
    <div class="relative z-10 flex flex-col items-center justify-center text-center px-6">
      <h1 class="text-xs font-mono uppercase tracking-widest mb-4" style="color: var(--text-faint)">Error 404</h1>
      <p class="text-xl font-serif italic mb-8" style="color: var(--foreground)">fatal error : page does not exists</p>
      
      <div class="flex gap-4">
        <a href="/" class="text-sm font-mono prose-link hover:text-white transition-colors">return home</a>
        <a href="https://github.com/sreeharipj" class="text-sm font-mono prose-link hover:text-white transition-colors">github</a>
      </div>
    </div>
  </main>

  <Footer />

  <script is:inline>
    const c = document.getElementById("c");
    const ctx = c.getContext("2d");
    const S = Math.sin;
    let t = 9;

    // Dynamically resize the canvas to perfectly match the browser window
    function resize() {
      c.width = window.innerWidth;
      c.height = window.innerHeight;
    }

    window.addEventListener("resize", resize);
    resize(); // Call once on load

    setInterval(() => {
      t += 4;
      ctx.clearRect(0, 0, c.width, c.height);
      
      const k = 700;
      
      // Calculate the exact center of the current screen
      const centerX = c.width / 2;
      const centerY = c.height / 2;

      for (let i = 700; --i; ) {
        let m = i + t;
        ctx.beginPath();
        
        // Detect current theme from the HTML attribute
        const isDark = document.documentElement.getAttribute("data-theme") === "dark";
        const brightness = isDark ? (i / 3) : (255 - (i / 3));
        ctx.fillStyle = `rgb(${brightness},${brightness},${brightness})`;
        
        const r = (S(t / 60 + m / k) / 2 + 1) * (m % 29 ? 100000 : 20000) / i;
        m = m * m; 
        
        // FIX: Replaced the hardcoded '1400' and '700' coordinates from the 
        // original snippet with 'centerX' and 'centerY'. 
        // We add (i - 350) to the X axis to keep the 3D horizontal depth effect.
        ctx.arc(
          centerX + (i - 350) + r * S(m), 
          centerY + S(m + 11) * r,       
          r / 2,
          0,
          7
        );
        ctx.fill();
      }
    }, 40);
  </script>
</Layout>

<style>
  main {
    background: var(--background);
  }
  :global(header), :global(footer) {
    z-index: 20;
  }
</style>