---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-1 font-mono rounded-md bg-accent/10 text-accent ring-1 ring-inset ring-accent/20 hover:bg-accent/20 transition-colors",
      { "text-xs px-2.5 py-1": size === "sm" },
      { "text-sm px-3 py-1.5": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-4": size === "lg" },
        { "size-3": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
