---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-4 -top-full z-50 bg-background px-3 py-2 text-foreground transition-all focus:top-4 text-sm"
>
  Skip to content
</a>

<header class="fixed top-0 left-0 right-0 z-50" style="background: var(--background); border-bottom: 1px solid var(--border);">
  <div class="mx-auto px-6 flex items-center justify-between h-12" style="max-width: 760px">
    <!-- Site Name / Logo -->
    <a
      href="/"
      class="text-sm font-mono text-foreground hover:opacity-70 transition-opacity"
    >
      {SITE.author}
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden sm:flex items-center gap-2">
      <a href="/posts" class:list={["px-2 py-1 text-sm transition-colors", isActive("/posts") ? "active-nav" : "text-foreground opacity-50 hover:opacity-100"]}>posts</a>
      <a href="/about" class:list={["px-2 py-1 text-sm transition-colors", isActive("/about") ? "active-nav" : "text-foreground opacity-50 hover:opacity-100"]}>about</a>
      <a href="/resume.pdf" class:list={["px-2 py-1 text-sm transition-colors", "text-foreground opacity-50 hover:opacity-100"]}>resume ↗</a>
    </nav>

    <!-- Right: search + theme toggle + mobile menu -->
    <div class="flex items-center gap-3">
      <LinkButton
        href="/search"
        class:list={["focus-outline flex p-2 opacity-50 hover:opacity-100 transition-opacity", { "opacity-100": isActive("/search") }]}
        title="Search"
        aria-label="search"
      >
        <IconSearch class="size-4" />
        <span class="sr-only">Search</span>
      </LinkButton>

      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          class="focus-outline relative size-8 p-2 opacity-50 hover:opacity-100 transition-opacity"
          title="Toggles light & dark"
          aria-label="auto"
          aria-live="polite"
        >
          <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90 size-4" />
          <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0 size-4" />
        </button>
      )}

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="focus-outline p-2 sm:hidden opacity-50 hover:opacity-100 transition-opacity"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <IconX id="close-icon" class="hidden size-4" />
        <IconMenuDeep id="menu-icon" class="size-4" />
      </button>
    </div>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden sm:hidden border-t" style="border-color: var(--border); background: var(--background)">
    <div class="px-6 py-4 flex flex-col gap-2">
      <a href="/posts" class:list={["px-2 py-2 text-sm", isActive("/posts") ? "active-nav" : "opacity-50"]}>posts</a>
      <a href="/about" class:list={["px-2 py-2 text-sm", isActive("/about") ? "active-nav" : "opacity-50"]}>about</a>
      <a href="/resume.pdf" class="px-2 py-2 text-sm opacity-50">resume ↗</a>
    </div>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const mobileMenu = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");
      mobileMenu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
